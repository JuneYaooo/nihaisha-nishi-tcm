# Text and knowledge search need no API key.
# Copy this file to .env and keep .env uncommitted. The runtime parses the
# nearest .env as KEY=VALUE without shell execution; exported values win.

# Recommended query-embedding backend for vector/hybrid: SiliconFlow BAAI/bge-m3.
SILICONFLOW_API_KEY=

# Optional CLI reranker model. In --reranker auto mode it is used only when the
# key above exists; use --reranker none to disable remote reranking.
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Optional local BAAI/bge-m3 backend, used only after installing .[local].
LOCAL_BGE_M3_USE_FP16=false
